# ---------------------------------------------------------------------------
# OpsPilot AI — environment configuration
# Copy to .env and adjust. Every value has a sane default for docker-compose.
# ---------------------------------------------------------------------------

# --- Core ---
OPSPILOT_SECRET_KEY=change-me-to-a-long-random-string
OPSPILOT_ENVIRONMENT=development
OPSPILOT_CORS_ORIGINS=http://localhost:3000

# --- Demo mode ---
# When true: public registration is disabled and the login page offers a one-click
# "Launch demo" that provisions an isolated, pre-seeded, sandboxed session. Sessions
# auto-expire after the TTL and are purged by a Celery beat job. Set the matching
# NEXT_PUBLIC_DEMO_MODE=true in the frontend build.
OPSPILOT_DEMO_MODE=false
OPSPILOT_DEMO_TTL_MINUTES=45
OPSPILOT_DEMO_MAX_ANALYSES=5
OPSPILOT_DEMO_MAX_CHAT_MESSAGES=40
OPSPILOT_DEMO_MAX_UPLOAD_MB=5

# --- Database (PostgreSQL with pgvector) ---
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=opspilot
POSTGRES_PASSWORD=opspilot
POSTGRES_DB=opspilot

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0

# --- LLM provider ---
# One of: anthropic | openrouter | ollama | openai_compatible
LLM_PROVIDER=anthropic

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-5

# Ollama (local models)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1:8b

# Any OpenAI-compatible endpoint (vLLM, LM Studio, Azure OpenAI proxy, ...)
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=

# --- Embeddings (RAG) ---
# One of: ollama | openai_compatible
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text
# Dimension of the embedding vectors. Must match the model AND the DB schema
# (see docs/configuration.md before changing on an existing database).
EMBEDDING_DIM=768

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
